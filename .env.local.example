# Copy this file to .env.local in the repository root for local runtime configuration.
# Never commit real secret values.

# Backend runtime secrets and settings.
FRED_API_KEY=
BLS_API_KEY=
BEA_API_KEY=
ALPHA_VANTAGE_API_KEY=
EIA_API_KEY=
KOREAEXIM_API_KEY=
OPENAI_API_KEY=
OPENAI_BRIEF_MODEL=gpt-5.5
OPENAI_AGENT_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional. In production, set this to https://<cloudfront-domain>/login/oauth2/code/google.
# Local Google OAuth can keep using http://localhost:8080/login/oauth2/code/google.
GOOGLE_REDIRECT_URI=
FRONTEND_BOARD_URL=http://localhost:5173/home
APP_PUBLIC_BASE_URL=http://localhost:5173

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=
SMTP_FROM=your-gmail-address@gmail.com
EMAIL_VERIFICATION_TTL_MINUTES=30
ADMIN_BOOTSTRAP_EMAILS=
AUTH_RATE_LIMIT_ENABLED=true
AUTH_CAPTCHA_ENABLED=false
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=
AUTH_ADMIN_MFA_ENABLED=true
APP_DATA_ENCRYPTION_KEY=

DB_URL=jdbc:postgresql://localhost:5432/jungle_ai
DB_USERNAME=jungle
DB_PASSWORD=jungle

ECON_SYNC_ENABLED=true
ECON_SYNC_FIXED_RATE_MS=14400000
ECON_STALE_AFTER_MINUTES=240
ECON_SYNC_DAILY_LIMIT=20
KOREAEXIM_EXCHANGE_ENABLED=true
KOREAEXIM_EXCHANGE_FIXED_RATE_MS=300000
KOREAEXIM_EXCHANGE_STALE_AFTER_MINUTES=55
KOREAEXIM_EXCHANGE_BUSINESS_DAY_CRON=0 10 11 * * MON-FRI

US_ECON_AGENTS_ENABLED=true
AGENT_WORKER_URL=http://localhost:8090
AGENT_WORKER_TOKEN=local-agent-token
AGENT_MCP_URL=http://localhost:8090/mcp/
AGENT_BACKEND_INTERNAL_URL=http://localhost:8080

# Frontend public build-time settings.
# Only VITE_* variables are exposed to browser code by Vite.
VITE_BACKEND_ORIGIN=http://localhost:8080
VITE_API_BASE_URL=
