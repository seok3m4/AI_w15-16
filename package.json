{
  "name": "cine-review-ai",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered movie review board built with React, NestJS, PostgreSQL, RAG, MCP, and an AI agent.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run start:dev -w apps/api",
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "prisma:format": "npm run prisma:format -w apps/api",
    "prisma:migrate": "npm run prisma:migrate -w apps/api",
    "prisma:generate": "npm run prisma:generate -w apps/api"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
