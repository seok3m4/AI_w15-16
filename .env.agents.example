# Copy this file to .env.agents.local for local development.
# Never commit real secret values.

# Enables the future US economy agent workflow.
US_ECON_AGENTS_ENABLED=false

# Human-filled OpenAI values.
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=

# Agent observability and review switches.
OPENAI_AGENT_TRACE_ENABLED=true
OPENAI_AGENT_EVALS_ENABLED=false
OPENAI_AGENT_HUMAN_REVIEW_REQUIRED=true

# Keep sample mode until live official data sources are connected.
US_ECON_DATA_MODE=sample

# Optional live-data keys, filled only when each connector is implemented.
BLS_API_KEY=
FRED_API_KEY=
NEWS_SEARCH_API_KEY=
