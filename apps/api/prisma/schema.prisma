// 📌 DB 테이블 구조 정의. 여기 작성한 모델을 기반으로 실제 DB 테이블이 만들어진다.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// 서비스에 가입한 사용자.
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  reviews      Review[]
  comments     Comment[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

/// TMDB에서 가져오거나 사용자가 리뷰에 연결한 영화 정보.
model Movie {
  id            String    @id @default(cuid())
  tmdbId        Int?      @unique
  title         String
  originalTitle String?
  overview      String?
  posterPath    String?
  releaseDate   DateTime?
  reviews       Review[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([title])
}

/// 사용자가 작성한 영화 리뷰 게시글.
model Review {
  id        String           @id @default(cuid())
  title     String
  content   String
  rating    Int?
  isSpoiler Boolean          @default(false)
  authorId  String
  movieId   String
  author    User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  movie     Movie            @relation(fields: [movieId], references: [id], onDelete: Cascade)
  comments  Comment[]
  tags      ReviewTag[]
  embedding ReviewEmbedding?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([authorId])
  @@index([movieId])
  @@index([createdAt])
}

/// 리뷰에 달리는 댓글.
model Comment {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  reviewId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
  @@index([reviewId])
}

/// 리뷰 검색과 분류에 사용하는 태그.
model Tag {
  id        String      @id @default(cuid())
  name      String      @unique
  reviews   ReviewTag[]
  createdAt DateTime    @default(now())
}

/// 리뷰와 태그의 N:M 관계를 표현하는 연결 테이블.
model ReviewTag {
  reviewId String
  tagId    String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([reviewId, tagId])
  @@index([tagId])
}

/// 리뷰 본문을 embedding vector로 변환해 저장하는 RAG용 테이블.
model ReviewEmbedding {
  id        String                       @id @default(cuid())
  reviewId  String                       @unique
  review    Review                       @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  embedding Unsupported("vector(1536)")?
  createdAt DateTime                     @default(now())
  updatedAt DateTime                     @updatedAt
}
