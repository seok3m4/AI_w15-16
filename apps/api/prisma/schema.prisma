// 📌 DB 테이블 구조 정의. 여기 작성한 모델을 기반으로 실제 DB 테이블이 만들어진다.
// Prisma Client를 생성해서 TypeScript 코드에서 DB를 타입 안전하게 사용할 수 있게 한다.
generator client {
  provider = "prisma-client-js"
}

// 이 프로젝트의 실제 데이터베이스가 PostgreSQL임을 Prisma에 알려준다.
datasource db {
  provider = "postgresql"
}

/// 서비스에 가입한 사용자.
model User {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String
  passwordHash String
  posts        Post[]
  comments     Comment[]
  savedPosts   SavedPost[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

/// 여행 코스 게시글.
model Post {
  id        String         @id @default(cuid())
  title     String
  content   String
  city      String
  duration  Int?
  authorId  String
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  Comment[]
  tags      PostTag[]
  places    Place[]
  savedBy   SavedPost[]
  embedding PostEmbedding?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([authorId])
  @@index([city])
  @@index([createdAt])
}

/// 사용자가 "나중에 보기"처럼 저장한 게시글. (User-Post N:M 북마크)
model SavedPost {
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, postId])
  @@index([postId])
  @@index([userId])
}

/// 여행 코스를 구성하는 개별 경유지(장소). 지도에 순서대로 표시된다.
model Place {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  lat       Float
  lng       Float
  order     Int
  createdAt DateTime @default(now())

  @@index([postId])
}

/// 게시글에 달리는 댓글.
model Comment {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  postId    String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
  @@index([postId])
}

/// 게시글 검색과 분류에 사용하는 태그.
model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  posts     PostTag[]
  createdAt DateTime  @default(now())
}

/// 게시글과 태그의 N:M 관계 연결 테이블.
model PostTag {
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

/// 게시글 본문을 embedding vector로 변환해 저장하는 RAG용 테이블.
model PostEmbedding {
  id        String                       @id @default(cuid())
  postId    String                       @unique
  post      Post                         @relation(fields: [postId], references: [id], onDelete: Cascade)
  embedding Unsupported("vector(1536)")?
  createdAt DateTime                     @default(now())
  updatedAt DateTime                     @updatedAt
}
