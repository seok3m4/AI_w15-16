# PostgreSQL 접속 주소
DATABASE_URL="postgresql://cine:cine_password@localhost:5433/cine_review_ai?schema=public"

# NestJS 백엔드 서버 포트
PORT=3000

# React 프론트엔드 주소
FRONTEND_URL="http://localhost:5173"

# React에서 호출할 백엔드 API 주소
VITE_API_BASE_URL="http://localhost:3000"

# JWT 토큰 서명에 사용하는 비밀키와 만료 시간
JWT_SECRET="cine-review-super-secret-key"
JWT_EXPIRES_IN="7d"

# OpenAI API key. RAG와 Agent에서 사용
OPENAI_API_KEY=""

# Kakao 지도 JavaScript SDK 키. React에서 지도 표시와 장소 검색에 사용
VITE_KAKAO_MAP_KEY=""

# Kakao REST API 키. MCP 서버가 Kakao Local API 장소 검색에 사용
KAKAO_REST_API_KEY=""
